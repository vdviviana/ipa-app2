<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBCEDB">

    <ImageView
        android:id="@+id/imgHeaderCircle"
        android:layout_width="430dp"
        android:layout_height="160dp"
        android:scaleType="fitXY"
        android:src="@drawable/ellipse_4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtIpa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="IPA"
        android:textAlignment="center"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="(INTERNATIONAL&#10;PHONETIC ALPHABET)"
        android:textAlignment="center"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/txtIpa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtConsonants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="CONSONANTS"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgHeaderCircle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="88dp"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:text="VOLVER"
        app:layout_constraintTop_toBottomOf="@id/txtConsonants"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <GridLayout
        android:id="@+id/gridConsonants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintTop_toBottomOf="@id/btnVolver"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnconsonants1"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:backgroundTint="#F4F0F0"
            android:text="ð"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants2"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:backgroundTint="#F4F0F0"
            android:text="θ"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants3"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:backgroundTint="#F4F0F0"
            android:text="v"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants4"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="z"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants5"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="ʃ"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants6"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="ŋ"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants7"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="h"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants8"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="tʃ"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants9"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="dʒ"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnconsonants10"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#F4F0F0"
            android:text="j"
            android:textAllCaps="false"
            android:textSize="24sp" />

        <Button
            android:id="@+id/btnInfoConsonants"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#2196F3"
            android:text="INFO"
            android:textAllCaps="false"
            android:textSize="18sp" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
